# Copy target: Polymarket username (e.g. "alice") or proxy wallet (0x...)
COPY_TARGET_USER=
# Or set proxy directly (overrides COPY_TARGET_USER)
# COPY_TARGET_PROXY=0x1234...

# Poll interval (ms)
COPY_POLL_INTERVAL_MS=15000
# Activity page size per poll (max 500)
COPY_ACTIVITY_LIMIT=100
# Size multiplier (e.g. 0.5 = half size, 2 = double)
COPY_SIZE_MULTIPLIER=1
# Max USDC per order (0 = no cap)
COPY_MAX_ORDER_USD=0
# Only copy TRADEs (true recommended)
COPY_TRADES_ONLY=true
# Dry run: log only, no orders
COPY_DRY_RUN=true

# Polymarket APIs (defaults shown)
# POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
# POLYMARKET_CLOB_URL=https://clob.polymarket.com
# POLYMARKET_CHAIN_ID=137

# Your wallet (required for live trading)
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_FUNDER_ADDRESS=0x...
# API creds auto-derived from wallet (no need to set)
# POLYMARKET_AUTO_DERIVE_API_KEY=true
# POLYMARKET_SIGNATURE_TYPE=0
